DATABASE_PATH=data/domains.db
LOG_LEVEL=INFO
OFFLINE_MODE=false

# Budget
MAX_BID=100
PREFERRED_MIN=10
PREFERRED_MAX=50
EXCEPTIONAL_MAX=300

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# APIs (optional - enables richer data)
CATCHDOMS_API_KEY=
CRAWLY_API_KEY=
AHREFS_API_KEY=
MOZ_API_KEY=
# Optional: Apollo.io API key for buyer discovery
# Apollo provides company search (275M+ contacts) — system works without it using free alternatives
APOLLO_API_KEY=
# Optional: Tomba.io API key for email finding
# Tomba provides email verification — system works without it using free alternatives
TOMBA_API_KEY=
