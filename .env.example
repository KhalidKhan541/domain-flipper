DATABASE_PATH=data/domains.db
LOG_LEVEL=INFO
OFFLINE_MODE=false

# Budget
MAX_BID=100
PREFERRED_MIN=10
PREFERRED_MAX=50
EXCEPTIONAL_MAX=300

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# APIs (optional - enables richer data)
CATCHDOMS_API_KEY=
CRAWLY_API_KEY=
AHREFS_API_KEY=
MOZ_API_KEY=
# Optional: Apollo.io API key for buyer discovery
APOLLO_API_KEY=
# Optional: Tomba.io API key for email finding
TOMBA_API_KEY=

# Trading — Wallet (No Bank Account Needed)
# Options: coinbase, phantom, metamask
WALLET_TYPE=coinbase
# Options: base, ethereum, solana
WALLET_CHAIN=base

# Trading — Escrow
# Chain for escrow contracts (base recommended — low fees)
ESCROW_CHAIN=base
# Auto-refund after hours (default 72)
ESCROW_TIMEOUT_HOURS=72

# Trading — Cashout (Convert USDC to local currency)
# Options: binance_p2p, paxful, manual
CASHOUT_METHOD=binance_p2p
# Your local currency (USD, EUR, INR, NGN, PHP, etc.)
CASHOUT_CURRENCY=USD
# How you want to receive fiat (bank_transfer, upi, paypal)
CASHOUT_PAYMENT_METHOD=bank_transfer

# Trading — Domain Transfer
# Where to receive purchased domains
PREFERRED_REGISTRAR=porkbun
# Cancel transfer if not completed (days)
TRANSFER_TIMEOUT_DAYS=10

# Trading — Verification
# Minimum ownership confidence to proceed (0.0 to 1.0)
MIN_OWNERSHIP_CONFIDENCE=0.7
# Require DNS check before purchase
REQUIRE_DNS_CHECK=true
